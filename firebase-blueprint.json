{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Full recipe details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "coverImage": { "type": "string" },
        "imageCredit": { "type": "string", "description": "Attribution/credit for the cover image" },
        "mealTime": { "type": "string", "enum": ["pagi", "siang", "sore", "malam"] },
        "condition": { "type": "string", "description": "e.g. maag, diabetes, etc." },
        "nutrition": {
          "type": "object",
          "properties": {
            "calories": { "type": "string" },
            "protein": { "type": "string" },
            "fat": { "type": "string" },
            "carbs": { "type": "string" }
          }
        },
        "ingredients": {
          "type": "array",
          "items": { "type": "string" }
        },
        "instructions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "number" },
              "text": { "type": "string" },
              "image": { "type": "string" },
              "imageCredit": { "type": "string", "description": "Attribution/credit for the step image" }
            }
          }
        },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "mealTime", "ingredients", "instructions"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment and rating",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "recipeId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recipeId", "userId", "text", "rating"]
    },
    "Suggestion": {
      "title": "Suggestion",
      "description": "User recipe suggestion to admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "added"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "ShoppingList": {
      "title": "Shopping List",
      "description": "User's shopping list items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "CustomRecipe": {
      "title": "Custom Recipe",
      "description": "User's personal saved custom recipes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "source": { "type": "string", "enum": ["chef_ai", "meal_planner", "magic_ingredients", "manual"] },
        "instructions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "number" },
              "text": { "type": "string" },
              "duration": { "type": "number", "description": "Optional timer in minutes" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "instructions"]
    },
    "AdminAccount": {
      "title": "Admin",
      "description": "Admin accounts records",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles"
    },
    "recipes": {
      "schema": "Recipe",
      "description": "Cooking recipes"
    },
    "recipes/{recipeId}/comments": {
      "schema": "Comment",
      "description": "Recipe reviews"
    },
    "suggestions": {
      "schema": "Suggestion",
      "description": "Recipe suggestions from users"
    },
    "shoppingLists": {
      "schema": "ShoppingList",
      "description": "User's individual shopping list"
    },
    "customRecipes": {
      "schema": "CustomRecipe",
      "description": "User's individual custom recipes"
    },
    "admins": {
        "schema": "AdminAccount",
        "description": "List of admin UIDs"
    }
  }
}
